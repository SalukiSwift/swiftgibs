+
+    struct votepick { string voter, map, modename; int mode; };
+    struct votecand { string map, modename; int mode, count; };
+    struct votecandless { bool operator()(const votecand &a, const votecand &b) const {
+        if(a.count != b.count) return a.count > b.count; // higher count first
+        return strcmp(a.map, b.map) < 0;                 // tie-break: map name asc (deterministic)
+    } };
+    vector<votepick> votepicks; // latest suggestion per voter
+    vector<votecand> votecands; // aggregated candidates, sorted by count desc
+    string myvotemap = "";      // local player's current pick (tracked at the N_MAPVOTE send)
+    int myvotemode = -1;
