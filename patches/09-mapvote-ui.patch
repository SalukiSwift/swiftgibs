+    ICOMMAND(getvotemode, "i", (int *i), result(votecands.inrange(*i) ? votecands[*i].modename : ""));
+    ICOMMAND(getvotecount,"i", (int *i), intret(votecands.inrange(*i) ? votecands[*i].count : 0));
+    ICOMMAND(getvotemymap,  "", (), result(myvotemap));
+    ICOMMAND(getvotemymode, "", (), result(myvotemode >= 0 ? server::modename(myvotemode) : ""));
+    ICOMMAND(castmapvote, "i", (int *i), { if(votecands.inrange(*i)) changemap(votecands[*i].map, votecands[*i].mode); });
+    ICOMMAND(_mapvotetest, "ssi", (char *voter, char *map, int *mode), recordvote(voter, map, server::modename(*mode)));
+    ICOMMAND(_mapvoteparse, "s", (char *msg), parsevotemsg(msg)); // feed a raw server line through the real parser
