+    void clearvotes() { votepicks.shrink(0); votecands.shrink(0); }
+
+    // copy src -> dst, dropping "\fX" colour codes (\f = 0x0c + 1 arg char) and trimming spaces.
+    // Modded servers colourise the voter/map/mode in the vote text; without this the mapshot path
+    // (packages/base/<map>.jpg) would embed \f codes and 404 to the placeholder cube.
+    void stripvotecolors(char *dst, const char *src)
+    {
+        int n = 0;
+        for(; *src && n < MAXSTRLEN-1; src++)
+        {
+            if(*src == '\f') { if(src[1]) src++; continue; }
+            dst[n++] = *src;
+        }
+        dst[n] = '\0';
+        int s = 0; while(dst[s] == ' ') s++;                                  // trim leading spaces
+        if(s) { int k = 0; while(dst[s]) dst[k++] = dst[s++]; dst[k] = '\0'; }
+        for(int e = (int)strlen(dst); e > 0 && dst[e-1] == ' '; e--) dst[e-1] = '\0'; // trailing
+    }
+
+    void rebuildvotecands()
+    {
+        votecands.shrink(0);
+        loopv(votepicks)
+        {
+            votepick &vp = votepicks[i];
+            votecand *c = NULL;
+            loopvj(votecands) if(!strcmp(votecands[j].map, vp.map) && votecands[j].mode == vp.mode)
+                { c = &votecands[j]; break; }
+            if(!c) { c = &votecands.add(); copystring(c->map, vp.map); copystring(c->modename, vp.modename);
+                     c->mode = vp.mode; c->count = 0; }
+            c->count++;
+        }
+        votecands.sort(votecandless());
+    }
+
+    void recordvote(const char *voter, const char *map, const char *modestr)
+    {
+        if(!voter[0] || !map[0]) return;
+        int mode = gamemode; // fallback to current mode if the name doesn't resolve (reworded server)
+        loopi(NUMGAMEMODES) { int m = STARTGAMEMODE+i; if(!strcmp(server::modename(m), modestr)) { mode = m; break; } }
+        votepick *vp = NULL;
+        loopv(votepicks) if(!strcmp(votepicks[i].voter, voter)) { vp = &votepicks[i]; break; }
+        if(!vp) { vp = &votepicks.add(); copystring(vp->voter, voter); }
+        copystring(vp->map, map); copystring(vp->modename, modestr); vp->mode = mode;
+        rebuildvotecands();
+    }
+
+    // parse one N_SERVMSG line; extract a "suggests ... on map ... (select map to vote)" broadcast
+    void parsevotemsg(const char *msg)
+    {
+        const char *sug = strstr(msg, " suggests ");
+        if(!sug) return;
+        const char *onmap = strstr(sug, " on map ");
+        if(!onmap) return;
+        const char *tail = strstr(onmap, " (select map to vote)");
+        if(!tail) return; // not a suggest broadcast (forced votes change map -> N_MAPCHANGE clears)
+        string rawvoter, rawmode, rawmap, voter, modestr, mapstr;
+        int vlen = min((int)(sug - msg), MAXSTRLEN-1); if(vlen < 0) return;
+        memcpy(rawvoter, msg, vlen); rawvoter[vlen] = '\0';
+        const char *ms = sug + 10;  // strlen(" suggests ")
+        int mlen = min((int)(onmap - ms), MAXSTRLEN-1); if(mlen < 0) return;
+        memcpy(rawmode, ms, mlen); rawmode[mlen] = '\0';
+        const char *ps = onmap + 8; // strlen(" on map ")
+        int plen = min((int)(tail - ps), MAXSTRLEN-1); if(plen < 0) return;
+        memcpy(rawmap, ps, plen); rawmap[plen] = '\0';
+        stripvotecolors(voter, rawvoter);   // modded servers colourise names/maps -> strip \f codes
+        stripvotecolors(modestr, rawmode);  // (+trim) so the mapshot path + mode name resolve cleanly
+        stripvotecolors(mapstr, rawmap);
+        recordvote(voter, mapstr, modestr);
+    }
+
