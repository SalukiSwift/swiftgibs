+    // === SwiftGibs killstreak HUD (top-right, escalating with streak) ===
+    VARP(killstreakhud, 0, 1, 1);
+    void drawkillstreak(int w, int h)
+    {
+        if(!killstreakhud || killstreak <= 0) return;
+        int s = 1800/4, x = 1800*w/h - s - s/10;      // minimap corner (capture.h:459)
+        int y = s/10;
+        if(cmode && m_teammode) y += s + s/12;         // below the minimap in team modes
+        else y = s/10;                                  // top-right in DM (no minimap)
+        // tier colour: <5 white, 5-9 yellow, 10-14 orange, 15-19 red, 20+ red+glow
+        bvec col(255,255,255);
+        if(killstreak >= 20) col = bvec(255, 40, 40);
+        else if(killstreak >= 15) col = bvec(255, 60, 60);
+        else if(killstreak >= 10) col = bvec(255, 150, 40);
+        else if(killstreak >= 5) col = bvec(255, 220, 40);
+        float scale = 1.0f + min(killstreak, 20) * 0.03f;   // grows with streak, capped
+        defformatstring(str, "%d", killstreak);
+        int tw, th; text_bounds(str, tw, th);
+        pushhudmatrix();
+        hudmatrix.translate(x + s/2, y, 0);
+        hudmatrix.scale(scale, scale, 1);
+        flushhudmatrix();
+        draw_text(str, -tw/2, 0, col.x, col.y, col.z, 255);
+        pophudmatrix();
+    }
