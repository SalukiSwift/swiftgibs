+// SwiftGibs: minimal scrollbar for the mini-console while browsing chat history
+// (x,y,w,h) describe the mini-console's on-screen box in the same coord space as drawconlines.
+void drawminiconindicator(int x, int y, int w, int h, int filter)
+{
+    if(w <= 0 || h <= 0) return;
+    filter &= CON_FLAGS;
+    int total = 0;
+    loopv(conlines) if(conlines[i].type&filter) total++;
+    if(total <= 0) return;
+    int visible = clamp(h/max(FONTH, 1), 1, total);
+    float barw = FONTH/6.0f, bx = x + w - barw;
+    hudnotextureshader->set();
+    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
+    gle::colorf(1, 1, 1, 0.25f);   // track
+    gle::defvertex(2);
+    gle::begin(GL_QUADS);
+    gle::attribf(bx, y);        gle::attribf(bx+barw, y);
+    gle::attribf(bx+barw, y+h); gle::attribf(bx, y+h);
+    gle::end();
+    float thumbh = h*clamp(visible/float(total), 0.08f, 1.0f);
+    float p = clamp(miniconskip/float(total), 0.0f, 1.0f);
+    float ty = y + (h - thumbh)*(1.0f - p);
+    gle::colorf(1, 1, 1, 0.6f);   // thumb
+    gle::defvertex(2);
+    gle::begin(GL_QUADS);
+    gle::attribf(bx, ty);            gle::attribf(bx+barw, ty);
+    gle::attribf(bx+barw, ty+thumbh); gle::attribf(bx, ty+thumbh);
+    gle::end();
+    hudshader->set();
+}
