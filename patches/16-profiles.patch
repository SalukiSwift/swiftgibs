+    // === SwiftGibs preferences profiles (Task 3): named save/load/delete slots for the
+    // full settings set. The canonical list of ident names lives in CubeScript (overlay
+    // alias sgProfileVars) so it can be edited without touching the engine; C++ only
+    // sanitises the profile name and writes the correct syntax per ident type (VARP vs
+    // alias), mirroring how the stock engine's writecfg() persists config.cfg. Loading
+    // needs no C++ (just `exec profiles/<name>.cfg`); listing reuses the stock loopfiles
+    // ICOMMAND directly from CubeScript.
+    bool validprofilename(const char *name)
+    {
+        if(!name || !name[0]) return false;
+        for(const char *s = name; *s; s++) if(!iscubealnum(*s) && *s!='-' && *s!='_') return false;
+        return true;
+    }
+    ICOMMAND(saveprofile, "s", (char *name),
+    {
+        if(!validprofilename(name)) { conoutf("invalid profile name: use letters, numbers, - and _ only"); return; }
+        const char *varlist = getalias("sgProfileVars");
+        if(!varlist || !varlist[0]) { conoutf("saveprofile: sgProfileVars not defined"); return; }
+        vector<char *> names;
+        explodelist(varlist, names);
+        defformatstring(fname, "profiles/%s.cfg", name);
+        stream *f = openutf8file(path(fname, true), "w");
+        if(!f) { conoutf("could not write profile: %s", name); names.deletearrays(); return; }
+        f->printf("// SwiftGibs profile: %s (auto-written by saveprofile)\n\n", name);
+        loopv(names)
+        {
+            ident *id = getident(names[i]);
+            if(!id) continue;
+            switch(id->type)
+            {
+                case ID_VAR:   f->printf("%s %d\n", names[i], *id->storage.i); break;
+                case ID_FVAR:  f->printf("%s %s\n", names[i], floatstr(*id->storage.f)); break;
+                case ID_ALIAS: f->printf("%s = [%s]\n", names[i], id->getstr()); break;
+            }
+        }
+        delete f;
+        names.deletearrays();
+        conoutf("profile %s saved", name);
+    });
+    ICOMMAND(delprofile, "s", (char *name),
+    {
+        if(!validprofilename(name)) { conoutf("invalid profile name: use letters, numbers, - and _ only"); return; }
+        defformatstring(fname, "profiles/%s.cfg", name);
+        remove(findfile(path(fname, true), "rb"));
+        conoutf("profile %s deleted", name);
+    });
+    // Exposed to CubeScript so the profiles gui can skip rendering rows for files
+    // whose names do not conform to the saveprofile charset (defence in depth: filenames on
+    // disk are not guaranteed to have been written by saveprofile - a downloaded profile
+    // pack or manual copy could contain CubeScript metacharacters, which would otherwise be
+    // baked verbatim into a clickable guibutton action and executed on click).
+    ICOMMAND(profilenamevalid, "s", (char *name), intret(validprofilename(name) ? 1 : 0));
+
