+    static inline void hbcol(int hex, float &r, float &g, float &b)
+    { r = ((hex>>16)&0xFF)/255.0f; g = ((hex>>8)&0xFF)/255.0f; b = (hex&0xFF)/255.0f; }
+
+    // draw the exact hit cylinder as a flat octagonal prism + a yaw/pitch facing prong
+    void drawhitboxshape(fpsent *d, int hex)
+    {
+        float r = d->radius, z0 = d->o.z - d->eyeheight, z1 = d->o.z + d->aboveeye, cx = d->o.x, cy = d->o.y;
+        const int S = 8;
+        float px[S], py[S];
+        loopi(S) { float a = i*2.0f*(float)M_PI/S; px[i] = cx + r*cosf(a); py[i] = cy + r*sinf(a); }
+        float cr, cg, cb; hbcol(hex, cr, cg, cb);
+        notextureshader->set();
+        loopi(S) // 8 side faces, shaded by facing so the prism reads as a solid
+        {
+            int j = (i+1)%S;
+            float nx = (px[i]+px[j])*0.5f - cx, ny = (py[i]+py[j])*0.5f - cy, nl = sqrtf(nx*nx+ny*ny);
+            float sh = nl>0 ? 0.60f + 0.40f*clamp(((nx/nl)*0.4f + (ny/nl)*0.6f)*0.5f + 0.5f, 0.0f, 1.0f) : 1.0f;
+            gle::colorf(cr*sh, cg*sh, cb*sh, 1.0f);
+            gle::defvertex(3);
+            gle::begin(GL_TRIANGLE_STRIP, 4);
+            gle::attrib(vec(px[i], py[i], z0)); gle::attrib(vec(px[i], py[i], z1));
+            gle::attrib(vec(px[j], py[j], z0)); gle::attrib(vec(px[j], py[j], z1));
+            gle::end();
+        }
+        loopk(2) // caps: top brighter, bottom darker
+        {
+            float z = k ? z1 : z0, sh = k ? 1.0f : 0.45f;
+            gle::colorf(cr*sh, cg*sh, cb*sh, 1.0f);
+            gle::defvertex(3);
+            gle::begin(GL_TRIANGLE_FAN, S+2);
+            gle::attrib(vec(cx, cy, z));
+            loopi(S+1) gle::attrib(vec(px[i%S], py[i%S], z));
+            gle::end();
+        }
+        vec dir; vecfromyawpitch(d->yaw, d->pitch, 1, 0, dir); // gaze prong = facing (yaw+pitch)
+        vec eye(cx, cy, d->o.z), tip = vec(eye).add(vec(dir).mul(r*1.9f));
+        vec side = vec(dir.y, -dir.x, 0);
+        if(side.magnitude() > 1e-4f) { side.normalize(); side.mul(r*0.5f); } else side = vec(r*0.5f, 0, 0);
+        gle::colorf(cr, cg, cb, 1.0f);
+        gle::defvertex(3);
+        gle::begin(GL_TRIANGLES, 3);
+        gle::attrib(tip); gle::attrib(vec(eye).add(side)); gle::attrib(vec(eye).sub(side));
+        gle::end();
+    }
