+    // === SwiftGibs reload metronome (audio tick/ding over the rifle reload) ===
+    VARP(reloadmetronome, 0, 0, 2);      // 0=off, 1=flat, 2=rising
+    VARP(reloadmetrovol, 0, 200, 255);   // playsound volume (0..255; 255=full)
+    void updatereloadmetronome()
+    {
+        static int mact = -1, mticks = 0; static bool mding = false;
+        const int DUR = 1500, BEAT = 500;
+        if(reloadmetronome == 0) { mact = -1; return; }
+        int start = -1;
+        fpsent *d = player1;
+        if(d->state == CS_ALIVE && d->lastattackgun == GUN_RIFLE)
+        { int e = lastmillis - d->lastaction; if(e >= 0 && e < DUR + 200) start = d->lastaction; }
+        if(start < 0) { int e = lastmillis - reloaddemostart; if(e >= 0 && e < DUR + 200) start = reloaddemostart; }
+        if(start < 0) { mact = -1; return; }
+        if(start != mact) { mact = start; mticks = 0; mding = false; }
+        int e = lastmillis - start, vol = reloadmetrovol;
+        while(mticks < 3 && e >= mticks * BEAT)
+        {
+            const char *snd = reloadmetronome == 2
+                ? (mticks == 0 ? "swiftgibs/tick_lo" : mticks == 1 ? "swiftgibs/tick_mid" : "swiftgibs/tick_hi")
+                : "swiftgibs/tick_mid";
+            if(vol > 0) playsoundname(snd, NULL, vol);   // vol 0 = muted (engine treats raw 0 as "default")
+            mticks++;
+        }
+        if(!mding && e >= DUR)
+        {
+            if(vol > 0) playsoundname("swiftgibs/ding", NULL, vol);
+            mding = true;
+        }
+    }
