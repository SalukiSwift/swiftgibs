+    // === SwiftGibs friend list (by displayed name, persistent) ===
+    vector<char *> friends;
+    bool isfriendname(const char *name)
+    {
+        if(!name || !name[0]) return false;
+        loopv(friends) if(!strcasecmp(friends[i], name)) return true;
+        return false;
+    }
+    void writefriends()
+    {
+        stream *f = openutf8file(path("friends.cfg", true), "w");
+        if(!f) return;
+        f->printf("// SwiftGibs friend list — these names are highlighted in-game\n\n");
+        loopv(friends) f->printf("addfriend %s\n", escapestring(friends[i]));
+        delete f;
+    }
+    ICOMMAND(addfriend, "s", (char *name),
+    {
+        if(!name[0] || isfriendname(name)) return;
+        friends.add(newstring(name));
+        writefriends();
+    });
+    ICOMMAND(delfriend, "s", (char *name),
+    {
+        loopv(friends) if(!strcasecmp(friends[i], name)) { delete[] friends[i]; friends.remove(i); writefriends(); break; }
+    });
+    ICOMMAND(isfriend, "s", (char *name), intret(isfriendname(name) ? 1 : 0));
+    ICOMMAND(clearfriends, "", (), { friends.deletearrays(); writefriends(); });
+    ICOMMAND(numfriends, "", (), intret(friends.length()));
+    ICOMMAND(getfriend, "i", (int *i), result(friends.inrange(*i) ? friends[*i] : ""));
+    // current OTHER players, for the "add from game" menu list
+    ICOMMAND(numplayers, "", (), intret(players.length()));
+    ICOMMAND(getplayername, "i", (int *i), result(players.inrange(*i) ? players[*i]->name : ""));
+
