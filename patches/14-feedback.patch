+// --- SwiftGibs: in-game feedback -> plain-HTTP POST to the feedback relay ---
+// Reuses the master-server raw-TCP pattern above (resolverwait +
+// connectwithtimeout + enet wait loops): blocks with a progress bar, esc
+// aborts, bounded by FEEDBACKLIMIT. Plaintext on purpose - the engine has no
+// TLS and nothing secret crosses this hop (the GitHub token stays server-side).
+// The POST is multipart/form-data: text fields (feedback + telemetry the
+// engine can see: map, mode, position, fps) plus an optional JPEG screenshot
+// taken by the F8 hotkey (screenshot/feedbackshot.jpg). Match stats arrive as
+// the script-assembled "info" argument (frags/deaths/... commands live in the
+// game dll side, not here).
+
+SVAR(feedbackhost, "salukiswift.com");
+VAR(feedbackport, 1, 8300, 0xFFFF);
+
+#define FEEDBACKLIMIT 15000
+#define FEEDBACKBOUNDARY "----SwiftGibsFeedback7d1298fa3e8a"
+
+static void feedbackstatus(const char *msg)
+{
+    alias("feedbackstatus", msg);
+    conoutf("feedback: %s", msg);
+}
+
+static void feedbackfield(vector<char> &out, const char *name, const char *value)
+{
+    defformatstring(head, "--" FEEDBACKBOUNDARY "\r\nContent-Disposition: form-data; name=\"%s\"\r\n\r\n", name);
+    out.put(head, strlen(head));
+    out.put(value, strlen(value));
+    out.put("\r\n", 2);
+}
+
+void sendfeedback(const char *name, const char *category, const char *version, const char *text, int shot, const char *info)
+{
+    if(!text[0]) { feedbackstatus("nothing to send"); return; }
+
+    // assemble the multipart body: player fields + engine telemetry
+    vector<char> body;
+    feedbackfield(body, "name", name);
+    feedbackfield(body, "category", category);
+    feedbackfield(body, "version", version);
+#ifdef WIN32
+    feedbackfield(body, "platform", "windows");
+#elif defined(__APPLE__)
+    feedbackfield(body, "platform", "mac");
+#else
+    feedbackfield(body, "platform", "linux");
+#endif
+    feedbackfield(body, "text", text);
+    if(info[0]) feedbackfield(body, "info", info);
+
+    const char *map = game::getclientmap();
+    if(map && map[0]) feedbackfield(body, "map", map);
+    const char *mode = game::getscreenshotinfo();
+    if(mode && mode[0]) feedbackfield(body, "mode", mode);
+    if(camera1)
+    {
+        defformatstring(pos, "%d %d %d", int(camera1->o.x), int(camera1->o.y), int(camera1->o.z));
+        feedbackfield(body, "pos", pos);
+    }
+    int fps = 0, bestdiff = 0, worstdiff = 0;
+    getfps(fps, bestdiff, worstdiff);
+    defformatstring(fpsstr, "%d", fps);
+    feedbackfield(body, "fps", fpsstr);
+
+    if(shot)
+    {
+        extern char *screenshotdir;
+        defformatstring(shotpath, "%s%sfeedbackshot.jpg", screenshotdir, screenshotdir[0] ? "/" : "");
+        size_t shotlen = 0;
+        char *shotdata = loadfile(path(shotpath), &shotlen, false);
+        if(shotdata)
+        {
+            const char *head = "--" FEEDBACKBOUNDARY "\r\nContent-Disposition: form-data; name=\"shot\"; filename=\"feedbackshot.jpg\"\r\nContent-Type: image/jpeg\r\n\r\n";
+            body.put(head, strlen(head));
+            body.put(shotdata, (int)shotlen);
+            body.put("\r\n", 2);
+            delete[] shotdata;
+        }
+        else conoutf("feedback: no screenshot found, sending without it");
+    }
+    body.put("--" FEEDBACKBOUNDARY "--\r\n", strlen("--" FEEDBACKBOUNDARY "--\r\n"));
+
+    ENetAddress address;
+    address.host = ENET_HOST_ANY;
+    address.port = feedbackport;
+    if(!resolverwait(feedbackhost, &address))
+    {
+        feedbackstatus("could not resolve the feedback server");
+        return;
+    }
+    ENetSocket sock = enet_socket_create(ENET_SOCKET_TYPE_STREAM);
+    if(sock == ENET_SOCKET_NULL) { feedbackstatus("could not open a socket"); return; }
+    enet_socket_set_option(sock, ENET_SOCKOPT_NONBLOCK, 1);
+    if(connectwithtimeout(sock, feedbackhost, address))
+    {
+        enet_socket_destroy(sock);
+        feedbackstatus("could not reach the feedback server");
+        return;
+    }
+
+    vector<char> req;
+    defformatstring(header,
+        "POST /feedback HTTP/1.1\r\n"
+        "Host: %s\r\n"
+        "User-Agent: SwiftGibs\r\n"
+        "Content-Type: multipart/form-data; boundary=" FEEDBACKBOUNDARY "\r\n"
+        "Content-Length: %d\r\n"
+        "Connection: close\r\n"
+        "\r\n",
+        feedbackhost, body.length());
+    req.put(header, strlen(header));
+    req.put(body.getbuf(), body.length());
+
+    defformatstring(progresstext, "sending feedback to %s... (esc to abort)", feedbackhost);
+    renderprogress(0, progresstext);
+
+    int starttime = SDL_GetTicks(), timeout = 0;
+    const char *out = req.getbuf();
+    int outlen = req.length();
+    ENetBuffer buf;
+    while(outlen > 0)
+    {
+        enet_uint32 events = ENET_SOCKET_WAIT_SEND;
+        if(enet_socket_wait(sock, &events, 250) >= 0 && events)
+        {
+            buf.data = (void *)out;
+            buf.dataLength = outlen;
+            int sent = enet_socket_send(sock, NULL, &buf, 1);
+            if(sent < 0) break;
+            out += sent;
+            outlen -= sent;
+        }
+        timeout = SDL_GetTicks() - starttime;
+        renderprogress(min(float(timeout)/FEEDBACKLIMIT, 1.0f), progresstext);
+        if(interceptkey(SDLK_ESCAPE)) timeout = FEEDBACKLIMIT + 1;
+        if(timeout > FEEDBACKLIMIT) break;
+    }
+
+    vector<char> data;
+    if(outlen <= 0) for(;;)
+    {
+        enet_uint32 events = ENET_SOCKET_WAIT_RECEIVE;
+        if(enet_socket_wait(sock, &events, 250) >= 0 && events)
+        {
+            if(data.length() >= data.capacity()) data.reserve(4096);
+            buf.data = data.getbuf() + data.length();
+            buf.dataLength = data.capacity() - data.length();
+            int recv = enet_socket_receive(sock, NULL, &buf, 1);
+            if(recv <= 0) break;
+            data.advance(recv);
+        }
+        timeout = SDL_GetTicks() - starttime;
+        renderprogress(min(float(timeout)/FEEDBACKLIMIT, 1.0f), progresstext);
+        if(interceptkey(SDLK_ESCAPE)) timeout = FEEDBACKLIMIT + 1;
+        if(timeout > FEEDBACKLIMIT) break;
+    }
+    enet_socket_destroy(sock);
+
+    if(outlen > 0 || data.empty())
+    {
+        feedbackstatus(timeout > FEEDBACKLIMIT ? "timed out - try again later" : "no reply from the feedback server");
+        return;
+    }
+    data.add('\0');
+
+    int code = 0;
+    if(sscanf(data.getbuf(), "HTTP/%*s %d", &code) != 1)
+    {
+        feedbackstatus("bad reply from the feedback server");
+        return;
+    }
+    char *msg = strstr(data.getbuf(), "\r\n\r\n");
+    if(msg)
+    {
+        msg += 4;
+        char *end = strpbrk(msg, "\r\n");
+        if(end) *end = '\0';
+    }
+    if(code == 200) feedbackstatus(msg && msg[0] ? msg : "sent - thank you!");
+    else if(msg && msg[0] && code >= 400 && code < 500) feedbackstatus(msg);
+    else
+    {
+        defformatstring(err, "feedback server error (%d)", code);
+        feedbackstatus(err);
+    }
+}
+
+ICOMMAND(sendfeedback, "ssssis", (const char *name, const char *category, const char *version, const char *text, int *shot, const char *info), sendfeedback(name, category, version, text, *shot, info));
+
+// --- SwiftGibs: launch-time update check (autoexec: checkupdate $swiftgibsversion) ---
+// Asks the relay for the latest release tag (GET /version - the engine cannot
+// reach GitHub's HTTPS itself). Deliberately SILENT and short-budget: it runs
+// during init, so no progress UI and no error spam - a dead relay or an
+// offline box just means no update banner. Results land in the aliases
+// swiftgibsupdate (0/1) + swiftgibslatest, which the main-menu gui reads.
+#define CHECKUPDLIMIT 2500
+
+static bool parseversion(const char *s, int &major, int &minor, int &patch)
+{
+    if(*s == 'v' || *s == 'V') s++;
+    major = minor = patch = 0;
+    return sscanf(s, "%d.%d.%d", &major, &minor, &patch) >= 2;
+}
+
+void checkupdate(const char *current)
+{
+    alias("swiftgibsupdate", "0");
+    alias("swiftgibslatest", "");
+
+    ENetAddress address;
+    address.host = ENET_HOST_ANY;
+    address.port = feedbackport;
+    if(!resolverwait(feedbackhost, &address)) return;
+    ENetSocket sock = enet_socket_create(ENET_SOCKET_TYPE_STREAM);
+    if(sock == ENET_SOCKET_NULL) return;
+    enet_socket_set_option(sock, ENET_SOCKOPT_NONBLOCK, 1);
+
+    // silent bounded connect (connectwithtimeout would paint a 20s progress bar)
+    if(enet_socket_connect(sock, &address) < 0) { enet_socket_destroy(sock); return; }
+    enet_uint32 events = ENET_SOCKET_WAIT_SEND | ENET_SOCKET_WAIT_RECEIVE;
+    if(enet_socket_wait(sock, &events, 2000) < 0 || !events) { enet_socket_destroy(sock); return; }
+    int connerror = 0;
+    if(enet_socket_get_option(sock, ENET_SOCKOPT_ERROR, &connerror) < 0 || connerror) { enet_socket_destroy(sock); return; }
+
+    defformatstring(reqstr, "GET /version HTTP/1.1\r\nHost: %s\r\nUser-Agent: SwiftGibs\r\nConnection: close\r\n\r\n", feedbackhost);
+    int starttime = SDL_GetTicks();
+    const char *out = reqstr;
+    int outlen = strlen(reqstr);
+    ENetBuffer buf;
+    while(outlen > 0)
+    {
+        enet_uint32 ev = ENET_SOCKET_WAIT_SEND;
+        if(enet_socket_wait(sock, &ev, 250) >= 0 && ev)
+        {
+            buf.data = (void *)out;
+            buf.dataLength = outlen;
+            int sent = enet_socket_send(sock, NULL, &buf, 1);
+            if(sent < 0) break;
+            out += sent;
+            outlen -= sent;
+        }
+        if(SDL_GetTicks() - starttime > CHECKUPDLIMIT) break;
+    }
+    vector<char> data;
+    if(outlen <= 0) for(;;)
+    {
+        enet_uint32 ev = ENET_SOCKET_WAIT_RECEIVE;
+        if(enet_socket_wait(sock, &ev, 250) >= 0 && ev)
+        {
+            if(data.length() >= data.capacity()) data.reserve(4096);
+            buf.data = data.getbuf() + data.length();
+            buf.dataLength = data.capacity() - data.length();
+            int recv = enet_socket_receive(sock, NULL, &buf, 1);
+            if(recv <= 0) break;
+            data.advance(recv);
+        }
+        if(SDL_GetTicks() - starttime > CHECKUPDLIMIT) break;
+    }
+    enet_socket_destroy(sock);
+    if(outlen > 0 || data.empty()) return;
+    data.add('\0');
+
+    int code = 0;
+    if(sscanf(data.getbuf(), "HTTP/%*s %d", &code) != 1 || code != 200) return;
+    char *tag = strstr(data.getbuf(), "\r\n\r\n");
+    if(!tag) return;
+    tag += 4;
+    char *end = strpbrk(tag, "\r\n");
+    if(end) *end = '\0';
+
+    int lmaj, lmin, lpat, cmaj, cmin, cpat;
+    if(!parseversion(tag, lmaj, lmin, lpat) || !parseversion(current, cmaj, cmin, cpat)) return;
+    if(lmaj > cmaj || (lmaj == cmaj && (lmin > cmin || (lmin == cmin && lpat > cpat))))
+    {
+        if(*tag == 'v' || *tag == 'V') tag++;
+        alias("swiftgibslatest", tag);
+        alias("swiftgibsupdate", "1");
+        conoutf("\f2SwiftGibs v%s is out (you have v%s) - run update-swiftgibs.bat in the game folder", tag, current);
+    }
+}
+
+ICOMMAND(checkupdate, "s", (const char *current), checkupdate(current));
