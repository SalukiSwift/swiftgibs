+    VARP(reloadcount, 0, 1, 7);   // 0=off, 1=Drift, 2=Slam, 3=Zoom, 4=Tick, 5=Rings, 6=Wedges, 7=Pulse
+
+    int reloaddemostart = -100000;
+    ICOMMAND(reloadcountdemo, "", (), { reloaddemostart = lastmillis; });
+
+    int reloadfreezems = -1;
+    ICOMMAND(reloadcountfreeze, "ii", (int *style, int *ms), { reloadcount = *style; reloadfreezems = *ms; });
+
+    // Returns elapsed ms in [0,1500) when any countdown source is active, else -1.
+    int reloadcountdownElapsed()
+    {
+        fpsent *d = hudplayer();
+        if(d->state == CS_SPECTATOR || d->state == CS_DEAD) return -1;
+
+        const int dur = 1500;
+
+        if(reloadfreezems >= 0) return reloadfreezems;
+
+        int e = lastmillis - d->lastaction;
+        if(d->lastattackgun == GUN_RIFLE && d->gunwait > 0 && e >= 0 && e < d->gunwait) return e;
+
+        int de = lastmillis - reloaddemostart;
+        if(de >= 0 && de < dur) return de;
+
+        return -1;
+    }
+
+    ICOMMAND(testreload, "", (), { player1->lastaction = lastmillis; player1->gunwait = guns[GUN_RIFLE].attackdelay; player1->lastattackgun = GUN_RIFLE; });
+
+    // Returns crosshair opacity: 1.0 normally; ramps 0.30→0.65 during the countdown so it
+    // stays visible but faded (player can aim; brightens toward "ready").
+    float reloadcrosshairfade()
+    {
+        if(reloadcount == 0) return 1.0f;
+        int elapsed = reloadcountdownElapsed();
+        if(elapsed < 0) return 1.0f;  // pop phase or no countdown
+        return 0.40f + 0.30f * (elapsed / 1500.0f);
+    }
+
+    // Returns crosshair scale: 1.0 normally, >1.0 during the 160ms pop-in after countdown ends.
+    float reloadcrosshairscale()
+    {
+        if(reloadcount == 0) return 1.0f;
+
+        const int popStart = 1500;
+        const int popDur   = 160;
+
+        fpsent *d = hudplayer();
+        if(d->state == CS_SPECTATOR || d->state == CS_DEAD) return 1.0f;
+
+        int t = -1;
+        if(reloadfreezems < 0)
+        {
+            int e = lastmillis - d->lastaction;
+            if(d->lastattackgun == GUN_RIFLE && e >= popStart && e < popStart + popDur)
+                t = e;
+            else
+            {
+                int de = lastmillis - reloaddemostart;
+                if(de >= popStart && de < popStart + popDur) t = de;
+            }
+        }
+        if(t < 0) return 1.0f;
+
+        float p = (t - popStart) / (float)popDur;  // 0..1 over the pop window
+        return 1.0f + 0.7f * (1.0f - p) * (1.0f - p);  // 1.7 → 1.0 (ease-out quad)
+    }
+
+    void drawreloadcountdown(int w, int h)
+    {
+        if(reloadcount == 0) return;
+
+        fpsent *d = hudplayer();
+        if(d->state == CS_SPECTATOR || d->state == CS_DEAD) return;
+
+        const int dur = 1500;
+        int elapsed = reloadcountdownElapsed();
+
+        if(elapsed < 0 || elapsed >= dur) return;
+
+        const int beat = dur / 3;  // 500ms per number
+        int idx = min(elapsed / beat, 2);
+        int number = 3 - idx;
+        float t = (elapsed - idx * beat) / (float)beat;  // 0..1 within this beat
+
+        // Center of the 1800-unit virtual space (shared by text and graphical styles)
+        float cx = w * 900.0f / h;
+        float cy = 900.0f;
+
+        // --- Graphical styles 5/6/7 (shapes, no text) ---
+        if(reloadcount >= 5)
+        {
+            switch(reloadcount)
+            {
+                case 5: // Rings: 3 concentric annuli, lose outermost each beat
+                {
+                    const int N = 48;
+                    const float radii[3] = {60.0f, 100.0f, 140.0f};
+                    const float thk = 12.0f;
+                    int numRings = 3 - idx; // rings to draw incl. the leaving one
+
+                    hudnotextureshader->set();
+                    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
+
+                    for(int ri = 0; ri < numRings; ri++)
+                    {
+                        float Ro = radii[ri] + thk * 0.5f;
+                        float Ri = radii[ri] - thk * 0.5f;
+                        float a = (ri == numRings - 1) ? 0.8f * (1.0f - t) : 0.8f;
+                        if(a < 0.01f) continue;
+
+                        gle::colorf(0.3f, 0.9f, 1.0f, a);
+                        gle::defvertex(2);
+                        gle::begin(GL_TRIANGLE_STRIP, (N + 1) * 2);
+                        for(int i = 0; i <= N; i++)
+                        {
+                            float ang = i * 2.0f * (float)M_PI / N;
+                            float cc = cosf(ang), ss = sinf(ang);
+                            gle::attribf(cx + Ro * cc, cy + Ro * ss);
+                            gle::attribf(cx + Ri * cc, cy + Ri * ss);
+                        }
+                        gle::end();
+                    }
+
+                    hudshader->set();
+                    return;
+                }
+                case 6: // Wedges: filled triangles pointing inward, spaced 120 deg, amber
+                {
+                    const float rbase = 115.0f, rapex = 50.0f, halfArc = 0.30f;
+                    const float wangles[3] = {
+                        -(float)M_PI / 2.0f,                              // top
+                        (float)M_PI / 6.0f,                               // lower-right
+                        5.0f * (float)M_PI / 6.0f                         // lower-left
+                    };
+                    int numWedges = 3 - idx;
+
+                    hudnotextureshader->set();
+                    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
+
+                    for(int wi = 0; wi < numWedges; wi++)
+                    {
+                        float a = (wi == numWedges - 1) ? 0.85f * (1.0f - t) : 0.85f;
+                        if(a < 0.01f) continue;
+
+                        float ang = wangles[wi];
+                        float bx1 = cx + rbase * cosf(ang - halfArc);
+                        float by1 = cy + rbase * sinf(ang - halfArc);
+                        float bx2 = cx + rbase * cosf(ang + halfArc);
+                        float by2 = cy + rbase * sinf(ang + halfArc);
+                        float ax  = cx + rapex * cosf(ang);
+                        float ay  = cy + rapex * sinf(ang);
+
+                        gle::colorf(1.0f, 0.55f, 0.1f, a);
+                        gle::defvertex(2);
+                        gle::begin(GL_TRIANGLES);
+                        gle::attribf(bx1, by1);
+                        gle::attribf(bx2, by2);
+                        gle::attribf(ax,  ay);
+                        gle::end();
+                    }
+
+                    hudshader->set();
+                    return;
+                }
+                case 7: // Pulse: one expanding ring per beat, additive blend
+                {
+                    const int N = 48;
+                    const float R  = 40.0f + 135.0f * t; // lerp(40, 175, t)
+                    const float thk = 10.0f;
+                    const float Ro = R + thk * 0.5f;
+                    const float Ri = R - thk * 0.5f;
+                    float a = 0.9f * (1.0f - t);
+
+                    hudnotextureshader->set();
+                    glBlendFunc(GL_SRC_ALPHA, GL_ONE);   // additive glow
+
+                    gle::colorf(0.6f, 0.95f, 1.0f, a);
+                    gle::defvertex(2);
+                    gle::begin(GL_TRIANGLE_STRIP, (N + 1) * 2);
+                    for(int i = 0; i <= N; i++)
+                    {
+                        float ang = i * 2.0f * (float)M_PI / N;
+                        float cc = cosf(ang), ss = sinf(ang);
+                        gle::attribf(cx + Ro * cc, cy + Ro * ss);
+                        gle::attribf(cx + Ri * cc, cy + Ri * ss);
+                    }
+                    gle::end();
+
+                    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA); // restore
+                    hudshader->set();
+                    return;
+                }
+            }
+            hudshader->set();
+            return;
+        }
+
+        // --- Text number styles (1-4) ---
+        defformatstring(numstr, "%d", number);
+        int tw, th;
+        text_bounds(numstr, tw, th);
+        if(th <= 0) return;
+
+        float alpha = 1.0f;
+        float styleScale = 1.0f;
+        float dx = 0.0f, dy = 0.0f;
+        int r = 255, g = 255, b = 255;
+        float TARGET_H = 180.0f; // smaller numbers, easier to aim through
+
+        switch(reloadcount)
+        {
+            case 1: // Drift: fade in fast then shrink+fade in place (no upward motion)
+                alpha = t < 0.12f ? t / 0.12f : 1.0f - (t - 0.12f) / 0.88f;
+                styleScale = 1.0f - 0.45f * t;
+                r = 255; g = 255; b = 255;
+                break;
+            case 2: // Slam: scale-overshoot bounce in, hold, fade
+                if(t < 0.18f)      styleScale = 1.6f - (0.9f) * (t / 0.18f);
+                else if(t < 0.30f) styleScale = 0.7f + (0.3f) * ((t - 0.18f) / 0.12f);
+                else               styleScale = 1.0f;
+                alpha = t < 0.65f ? 1.0f : 1.0f - (t - 0.65f) / 0.35f;
+                r = 255; g = 200; b = 40;
+                break;
+            case 3: // Zoom: rush from small to large while fading (trimmed scale)
+                styleScale = 0.5f + 1.0f * t;
+                alpha = 1.0f - t * t;
+                r = 255; g = 80; b = 60;
+                break;
+            case 4: // Tick: small, soft fade in/out in place
+                TARGET_H = 130.0f;
+                styleScale = 1.0f;
+                alpha = (t < 0.25f ? t / 0.25f : (t > 0.6f ? 1.0f - (t - 0.6f) / 0.4f : 1.0f)) * 0.7f;
+                r = 220; g = 235; b = 255;
+                break;
+            default: return;
+        }
+
+        alpha = max(0.0f, min(1.0f, alpha));
+        if(alpha < 0.01f) return;
+
+        float baseS = TARGET_H / (float)th;
+        float s = baseS * styleScale;
+
+        pushhudmatrix();
+        hudmatrix.translate(cx + dx, cy + dy, 0);
+        hudmatrix.scale(s, s, 1);
+        flushhudmatrix();
+
+        int a = int(alpha * 255.0f + 0.5f);
+        draw_text(numstr, -tw/2, -th/2, r, g, b, a);
+
+        pophudmatrix();
+    }
+
