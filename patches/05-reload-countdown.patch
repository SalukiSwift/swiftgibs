+    // per-beat colour journey: idx 0=count3 cyan, 1=count2 amber, 2=count1 hot
+    static void reloadbeatcolor(int idx, float &r, float &g, float &b)
+    {
+        static const float C[3][3] = {{0.25f,0.85f,1.00f},{1.00f,0.65f,0.15f},{1.00f,0.28f,0.22f}};
+        int i = clamp(idx, 0, 2); r = C[i][0]; g = C[i][1]; b = C[i][2];
+    }
+    static inline float beatpunch(float t) { return t < 0.18f ? t / 0.18f : 1.0f; }
+    static inline float easeoutquad(float p) { p = clamp(p, 0.0f, 1.0f); return 1.0f - (1.0f - p) * (1.0f - p); }
+
+    // Draw a filled annulus (ring) in the hud space centred at (cx,cy).
+    static void reloadring(float cx, float cy, float R, float thk, float r, float g, float b, float a)
+    {
+        if(a < 0.01f || R <= 0.0f) return;
+        const int N = 56; float Ro = R + thk*0.5f, Ri = max(0.0f, R - thk*0.5f);
+        gle::colorf(r, g, b, a);
+        gle::defvertex(2);
+        gle::begin(GL_TRIANGLE_STRIP, (N + 1) * 2);
+        for(int i = 0; i <= N; i++) { float ang = i*2.0f*(float)M_PI/N, cc = cosf(ang), ss = sinf(ang); gle::attribf(cx+Ro*cc, cy+Ro*ss); gle::attribf(cx+Ri*cc, cy+Ri*ss); }
+        gle::end();
+    }
+    static void reloaddisc(float cx, float cy, float R, float r, float g, float b, float a)
+    {
+        if(a < 0.01f || R <= 0.0f) return;
+        const int N = 40;
+        gle::colorf(r, g, b, a);
+        gle::defvertex(2);
+        gle::begin(GL_TRIANGLE_FAN, N + 2);
+        gle::attribf(cx, cy);
+        for(int i = 0; i <= N; i++) { float ang = i*2.0f*(float)M_PI/N; gle::attribf(cx + R*cosf(ang), cy + R*sinf(ang)); }
+        gle::end();
+    }
+
+    // Pop-phase timer: elapsed in [0,RC_POP) during the READY pop window, else -1 (honors freeze).
+    int reloadpopElapsed()
+    {
+        if(reloadcount == 0 && reloadflash == 0) return -1;   // pop window also drives the decoupled ready-flash
+        if(reloadfreezems >= 0)
+            return (reloadfreezems >= RC_DUR && reloadfreezems < RC_DUR + RC_POP) ? reloadfreezems - RC_DUR : -1;
+        int de = lastmillis - reloaddemostart;                 // demo previews render anywhere,
+        if(de >= RC_DUR && de < RC_DUR + RC_POP) return de - RC_DUR;   // menus included
+        fpsent *d = hudplayer();
+        if(d->state == CS_SPECTATOR || d->state == CS_DEAD) return -1;
+        int e = lastmillis - d->lastaction;
+        if(d->lastattackgun == GUN_RIFLE && e >= RC_DUR && e < RC_DUR + RC_POP) return e - RC_DUR;
+        return -1;
+    }
+
+    // Crosshair opacity: full normally; faded-but-aimable during the count (brightens toward ready).
+    float reloadcrosshairfade()
+    {
+        if(reloadcount == 0) return 1.0f;
+        int elapsed = reloadcountdownElapsed();
+        if(elapsed < 0 || elapsed >= RC_DUR) return 1.0f;
+        if(reloadcount == 6) { float bt = (elapsed % (RC_DUR/3)) / (float)(RC_DUR/3); return 0.50f + 0.50f * (1.0f - bt) * (1.0f - bt); }
+        return 0.45f + 0.30f * (elapsed / (float)RC_DUR);
+    }
+
+    // Crosshair scale: punchy pop at ready; per-beat pulse for the Crosshair-Pulse style.
+    float reloadcrosshairscale()
+    {
+        if(reloadcount == 0) return 1.0f;
+        if(reloadcount == 6)
+        {
+            int ce = reloadcountdownElapsed();
+            if(ce >= 0 && ce < RC_DUR) { float bt = (ce % (RC_DUR/3)) / (float)(RC_DUR/3); return 1.0f + 0.85f * (1.0f - easeoutquad(bt)); }
+        }
+        int t = reloadpopElapsed();
+        if(t < 0) return 1.0f;
+        float p = t / (float)RC_POP;
+        return 1.0f + 0.9f * (1.0f - easeoutquad(p));
+    }
+
+    void drawreloadcountdown(int w, int h)
+    {
+        if(reloadcount == 0 && reloadflash == 0) return;   // draw if EITHER the countdown or the ready-flash is on
+        if(reloaddemoing() && !reloadoverlaypass) return;   // demos draw AFTER the gui pass (menus would cover them)
+        fpsent *d = hudplayer();
+        if(d->state == CS_SPECTATOR || d->state == CS_DEAD) return;
+
+        float cx = w * 900.0f / h;
+        float cy = 900.0f;
+
+        // Fire-ready flash (independent of reloadcount): one of 8 styles in the pop window.
+        {
+            int pe = reloadpopElapsed();
+            if(pe >= 0)
+            {
+                float p = pe / (float)RC_POP;
+                float a = 1.0f - p;
+                if(reloadflash)
+                {
+                    hudnotextureshader->set();
+                    glBlendFunc(GL_SRC_ALPHA, GL_ONE);
+                    switch(reloadflash)
+                    {
+                        case 1: reloaddisc(cx, cy, 7.0f, 0.35f, 1.0f, 0.45f, 0.55f*a); break;
+                        case 2: reloaddisc(cx, cy, 14.0f*(1.0f-0.3f*p), 0.45f, 1.0f, 0.55f, 0.8f*a); break;
+                        case 3: reloadring(cx, cy, 24.0f + 70.0f*easeoutquad(p), 7.0f, 0.40f, 1.0f, 0.50f, a); break;
+                        case 4:
+                            reloadring(cx, cy, 60.0f + 300.0f*easeoutquad(p), 26.0f, 0.40f, 1.0f, 0.50f, a);
+                            reloaddisc(cx, cy, 55.0f*(1.0f-p), 0.55f, 1.0f, 0.60f, 0.7f*(1.0f-p*p)); break;
+                        case 5: reloaddisc(cx, cy, 150.0f*(0.6f+0.4f*p), 0.35f, 1.0f, 0.55f, 0.5f*a); break;
+                        case 6: for(int bi=0;bi<3;bi++) reloadring(cx, cy, 40.0f + 120.0f*bi + 220.0f*easeoutquad(p), 16.0f, 0.40f, 1.0f, 0.50f, a*(1.0f-0.22f*bi)); break;
+                        case 7:
+                        {
+                            float w2 = cx*2.0f, h2 = cy*2.0f, th = 26.0f*a + 6.0f;
+                            gle::colorf(0.30f, 1.0f, 0.45f, 0.6f*a);
+                            gle::defvertex(2); gle::begin(GL_QUADS);
+                            gle::attribf(0,0); gle::attribf(w2,0); gle::attribf(w2,th); gle::attribf(0,th);
+                            gle::attribf(0,h2-th); gle::attribf(w2,h2-th); gle::attribf(w2,h2); gle::attribf(0,h2);
+                            gle::attribf(0,0); gle::attribf(th,0); gle::attribf(th,h2); gle::attribf(0,h2);
+                            gle::attribf(w2-th,0); gle::attribf(w2,0); gle::attribf(w2,h2); gle::attribf(w2-th,h2);
+                            gle::end(); break;
+                        }
+                    }
+                    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
+                    hudshader->set();
+                }
+                return;
+            }
+        }
+
+        int elapsed = reloadcountdownElapsed();
+        if(elapsed < 0 || elapsed >= RC_DUR) return;
+
+        const int beat = RC_DUR / 3;
+        int idx = min(elapsed / beat, 2);
+        int number = 3 - idx;
+        float t = (elapsed - idx * beat) / (float)beat;
+
+        float cr, cg, cb; reloadbeatcolor(idx, cr, cg, cb);
+
+        switch(reloadcount)
+        {
+            case 1: // Rings -- N solid rings (=remaining count), current-beat colour, per-beat scale punch
+            {
+                int numRings = 3 - idx;
+                float pop = 1.0f + 0.30f * (1.0f - beatpunch(t));
+                hudnotextureshader->set();
+                glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
+                for(int ri = 0; ri < numRings; ri++)
+                    reloadring(cx, cy, (46.0f + 40.0f * ri) * pop, 20.0f, cr, cg, cb, 0.90f - 0.16f * ri);
+                hudshader->set();
+                return;
+            }
+            case 2: // Pulse -- one expanding ping per beat, additive, colour journey, brighter last beat
+            {
+                float pr = easeoutquad(t);
+                float a = (0.75f + (idx == 2 ? 0.25f : 0.0f)) * (1.0f - pr);
+                hudnotextureshader->set();
+                glBlendFunc(GL_SRC_ALPHA, GL_ONE);
+                reloadring(cx, cy, 40.0f + 175.0f * pr, 16.0f, cr, cg, cb, a);
+                glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
+                hudshader->set();
+                return;
+            }
+            case 3: // Collapse -- ring contracts to the crosshair, arriving at fire-time
+            {
+                float R = 190.0f * (1.0f - easeoutquad(t)) + 8.0f;
+                float a = 0.90f * (0.35f + 0.65f * t);
+                hudnotextureshader->set();
+                glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
+                reloadring(cx, cy, R, 18.0f, cr, cg, cb, a);
+                hudshader->set();
+                return;
+            }
+            case 4: // Sweep -- arc fills clockwise, full circle at fire-time, tick each beat
+            {
+                const int N = 72; const float Ro = 128.0f, Ri = 106.0f;
+                float frac = elapsed / (float)RC_DUR;
+                int segs = max(1, (int)(N * frac + 0.5f));
+                float tick = 1.0f - min(1.0f, (elapsed % beat) / 110.0f);
+                float a = 0.80f + 0.20f * tick;
+                hudnotextureshader->set();
