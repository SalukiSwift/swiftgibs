+                hudmatrix.translate(cx, cy + 165.0f, 0);
+                hudmatrix.scale(s, s, 1);
+                flushhudmatrix();
+                draw_text(numstr, -tw/2, -th/2, int(cr*255.0f), int(cg*255.0f), int(cb*255.0f), int(alpha*255.0f));
+                pophudmatrix();
+                return;
+            }
+            case 8: // Edge-beats -- screen-edge bars flash in the beat colour on each 3-2-1 beat
+            {
+                float pulse = 1.0f - beatpunch(t);   // sharp at beat onset, fades over ~90ms
+                float th = 34.0f * pulse + 3.0f;
+                float w2 = cx*2.0f, h2 = cy*2.0f;
