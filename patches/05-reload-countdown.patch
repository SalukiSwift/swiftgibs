+    // Draw a filled annulus (ring) in the hud space centred at (cx,cy).
+    static void reloadring(float cx, float cy, float R, float thk, float r, float g, float b, float a)
+    {
+        cueapply(r, g, b, a);
+        if(a < 0.01f || R <= 0.0f) return;
+        const int N = 56; float Ro = R + thk*0.5f, Ri = max(0.0f, R - thk*0.5f);
+        gle::colorf(r, g, b, a);
+        gle::defvertex(2);
+        gle::begin(GL_TRIANGLE_STRIP, (N + 1) * 2);
+        for(int i = 0; i <= N; i++) { float ang = i*2.0f*(float)M_PI/N, cc = cosf(ang), ss = sinf(ang); gle::attribf(cx+Ro*cc, cy+Ro*ss); gle::attribf(cx+Ri*cc, cy+Ri*ss); }
+        gle::end();
+    }
+    static void reloaddisc(float cx, float cy, float R, float r, float g, float b, float a)
+    {
+        cueapply(r, g, b, a);
+        if(a < 0.01f || R <= 0.0f) return;
+        const int N = 40;
+        gle::colorf(r, g, b, a);
+        gle::defvertex(2);
+        gle::begin(GL_TRIANGLE_FAN, N + 2);
+        gle::attribf(cx, cy);
+        for(int i = 0; i <= N; i++) { float ang = i*2.0f*(float)M_PI/N; gle::attribf(cx + R*cosf(ang), cy + R*sinf(ang)); }
+        gle::end();
+    }
+
+    // Axis-aligned filled bar centred at (cx,cy); honours the active cue colour transform.
+    static void reloadbar(float cx, float cy, float halfw, float halfh, float r, float g, float b, float a)
+    {
+        cueapply(r, g, b, a);
+        if(a < 0.01f) return;
+        gle::colorf(r, g, b, a);
+        gle::defvertex(2);
+        gle::begin(GL_QUADS);
+        gle::attribf(cx-halfw, cy-halfh); gle::attribf(cx+halfw, cy-halfh);
+        gle::attribf(cx+halfw, cy+halfh); gle::attribf(cx-halfw, cy+halfh);
+        gle::end();
+    }
+    // Rotated stroke from radius `inner` to `outer` along angle `ang`, thickness thk.
+    static void cuestroke(float cx, float cy, float ang, float inner, float outer, float thk, float r, float g, float b, float a)
+    {
+        cueapply(r, g, b, a);
+        if(a < 0.01f || outer <= inner) return;
+        float ca = cosf(ang), sa = sinf(ang), px = -sa*thk*0.5f, py = ca*thk*0.5f;
+        float x1 = cx + ca*inner, y1 = cy + sa*inner, x2 = cx + ca*outer, y2 = cy + sa*outer;
+        gle::colorf(r, g, b, a);
+        gle::defvertex(2);
+        gle::begin(GL_QUADS);
+        gle::attribf(x1+px, y1+py); gle::attribf(x2+px, y2+py);
+        gle::attribf(x2-px, y2-py); gle::attribf(x1-px, y1-py);
+        gle::end();
+    }
