         pophudmatrix();
     }
 
+    VARP(reloadcount, 0, 1, 4);   // 0=off, 1=Drift, 2=Slam, 3=Zoom, 4=Tick (persistent)
+
+    int reloaddemostart = -100000;
+    ICOMMAND(reloadcountdemo, "", (), { reloaddemostart = lastmillis; });
+
+    int reloadfreezems = -1;
+    ICOMMAND(reloadcountfreeze, "ii", (int *style, int *ms), { reloadcount = *style; reloadfreezems = *ms; });
+
+    // Returns elapsed ms in [0,1500) when any countdown source is active, else -1.
+    int reloadcountdownElapsed()
+    {
+        fpsent *d = hudplayer();
+        if(d->state == CS_SPECTATOR || d->state == CS_DEAD) return -1;
+
+        const int dur = 1500;
+
+        if(reloadfreezems >= 0) return reloadfreezems;
+
+        int e = lastmillis - d->lastaction;
+        if(d->lastattackgun == GUN_RIFLE && d->gunwait > 0 && e >= 0 && e < d->gunwait) return e;
+
+        int de = lastmillis - reloaddemostart;
+        if(de >= 0 && de < dur) return de;
+
+        return -1;
+    }
+
+    ICOMMAND(testreload, "", (), { player1->lastaction = lastmillis; player1->gunwait = guns[GUN_RIFLE].attackdelay; player1->lastattackgun = GUN_RIFLE; });
+
+    // Returns crosshair scale: 1.0 normally, >1.0 during the 160ms pop-in after countdown ends.
+    float reloadcrosshairscale()
+    {
+        if(reloadcount == 0) return 1.0f;
+
+        const int popStart = 1500;
+        const int popDur   = 160;
+
+        fpsent *d = hudplayer();
+        if(d->state == CS_SPECTATOR || d->state == CS_DEAD) return 1.0f;
+
+        int t = -1;
+        if(reloadfreezems < 0)
+        {
+            int e = lastmillis - d->lastaction;
+            if(d->lastattackgun == GUN_RIFLE && e >= popStart && e < popStart + popDur)
+                t = e;
+            else
+            {
+                int de = lastmillis - reloaddemostart;
+                if(de >= popStart && de < popStart + popDur) t = de;
+            }
+        }
+        if(t < 0) return 1.0f;
+
+        float p = (t - popStart) / (float)popDur;  // 0..1 over the pop window
+        return 1.0f + 0.7f * (1.0f - p) * (1.0f - p);  // 1.7 → 1.0 (ease-out quad)
+    }
+
+    void drawreloadcountdown(int w, int h)
+    {
+        if(reloadcount == 0) return;
+
+        fpsent *d = hudplayer();
+        if(d->state == CS_SPECTATOR || d->state == CS_DEAD) return;
+
+        const int dur = 1500;
+        int elapsed = reloadcountdownElapsed();
+
+        if(elapsed < 0 || elapsed >= dur) return;
+
+        const int beat = dur / 3;  // 500ms per number
+        int idx = min(elapsed / beat, 2);
+        int number = 3 - idx;
+        float t = (elapsed - idx * beat) / (float)beat;  // 0..1 within this beat
+
+        defformatstring(numstr, "%d", number);
+        int tw, th;
+        text_bounds(numstr, tw, th);
+        if(th <= 0) return;
+
+        // Center of the 1800-unit virtual space
+        float cx = w * 900.0f / h;
+        float cy = 900.0f;
+
+        float alpha = 1.0f;
+        float styleScale = 1.0f;
+        float dx = 0.0f, dy = 0.0f;
+        int r = 255, g = 255, b = 255;
+        float TARGET_H = 300.0f;
+
+        switch(reloadcount)
+        {
+            case 1: // Drift: fade in fast then shrink+rise+fade
+                alpha = t < 0.12f ? t / 0.12f : 1.0f - (t - 0.12f) / 0.88f;
+                styleScale = 1.0f - 0.45f * t;
+                dy = -260.0f * t;
+                r = 255; g = 255; b = 255;
+                break;
+            case 2: // Slam: scale-overshoot bounce in, hold, fade
+                if(t < 0.18f)      styleScale = 1.6f - (0.9f) * (t / 0.18f);
+                else if(t < 0.30f) styleScale = 0.7f + (0.3f) * ((t - 0.18f) / 0.12f);
+                else               styleScale = 1.0f;
+                alpha = t < 0.65f ? 1.0f : 1.0f - (t - 0.65f) / 0.35f;
+                r = 255; g = 200; b = 40;
+                break;
+            case 3: // Zoom: rush from small to large while fading
+                styleScale = 0.5f + 1.6f * t;
+                alpha = 1.0f - t * t;
+                r = 255; g = 80; b = 60;
+                break;
+            case 4: // Tick: small, soft fade in/out in place
+                TARGET_H = 190.0f;
+                styleScale = 1.0f;
+                alpha = (t < 0.25f ? t / 0.25f : (t > 0.6f ? 1.0f - (t - 0.6f) / 0.4f : 1.0f)) * 0.7f;
+                r = 220; g = 235; b = 255;
+                break;
+            default: return;
+        }
+
+        alpha = max(0.0f, min(1.0f, alpha));
+        if(alpha < 0.01f) return;
+
+        float baseS = TARGET_H / (float)th;
+        float s = baseS * styleScale;
+
+        pushhudmatrix();
+        hudmatrix.translate(cx + dx, cy + dy, 0);
+        hudmatrix.scale(s, s, 1);
+        flushhudmatrix();
+
+        int a = int(alpha * 255.0f + 0.5f);
+        draw_text(numstr, -tw/2, -th/2, r, g, b, a);
+
+        pophudmatrix();
+    }
+
     void gameplayhud(int w, int h)
     {
