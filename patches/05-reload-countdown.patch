+    static int cuehue = 0, cuemono = 0, cuealphav = 100;   // active family transform
+    static void cuefamily(int hue, int mono, int alpha) { cuehue = hue; cuemono = mono; cuealphav = alpha; }
+    static void cueapply(float &r, float &g, float &b, float &a)
+    {
+        if(cuemono) { float l = 0.299f*r + 0.587f*g + 0.114f*b; r = g = b = l; }
+        else if(cuehue)
+        {
+            float U = cosf(cuehue*(float)M_PI/180.0f), W = sinf(cuehue*(float)M_PI/180.0f);
+            float nr = (.299f+.701f*U+.168f*W)*r + (.587f-.587f*U+.330f*W)*g + (.114f-.114f*U-.497f*W)*b;
+            float ng = (.299f-.299f*U-.328f*W)*r + (.587f+.413f*U+.035f*W)*g + (.114f-.114f*U+.292f*W)*b;
+            float nb = (.299f-.300f*U+1.25f*W)*r + (.587f-.588f*U-1.05f*W)*g + (.114f+.886f*U-.203f*W)*b;
+            r = clamp(nr, 0.0f, 1.0f); g = clamp(ng, 0.0f, 1.0f); b = clamp(nb, 0.0f, 1.0f);
+        }
+        a *= cuealphav / 100.0f;
+    }
