+                gle::colorf(cr, cg, cb, a);
+                gle::defvertex(2);
+                gle::begin(GL_TRIANGLE_STRIP, (segs + 1) * 2);
+                for(int i = 0; i <= segs; i++) { float ang = -(float)M_PI/2.0f + (i/(float)N)*2.0f*(float)M_PI, cc = cosf(ang), ss = sinf(ang); gle::attribf(cx+Ro*cc, cy+Ro*ss); gle::attribf(cx+Ri*cc, cy+Ri*ss); }
+                gle::end();
+                hudshader->set();
+                return;
+            }
+            case 5: // Pips -- 3 charges ring the crosshair; deplete one per beat (ghost when spent)
+            {
+                const float ringR = 82.0f, pipR = 21.0f;
+                hudnotextureshader->set();
+                glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
+                reloadring(cx, cy, ringR, 3.0f, cr, cg, cb, 0.22f);   // faint connecting ring
+                for(int k = 0; k < 3; k++)
+                {
+                    float ang = -(float)M_PI/2.0f + k * (2.0f*(float)M_PI/3.0f);
+                    float px = cx + ringR*cosf(ang), py = cy + ringR*sinf(ang);
+                    bool lit = (k < number);
+                    bool spending = (k == number - 1);
+                    if(!lit) { reloadring(px, py, pipR*0.85f, 4.0f, cr, cg, cb, 0.20f); continue; }  // ghost
+                    float a = spending ? (1.0f - easeoutquad(t)) : 0.92f;
+                    float sc = spending ? (1.0f + 0.6f * beatpunch(t) * (1.0f - t)) : 1.0f;
+                    reloaddisc(px, py, pipR * sc, cr, cg, cb, a);
+                }
+                hudshader->set();
+                return;
+            }
+            case 6: // Crosshair Pulse -- effect is in the crosshair hooks; nothing drawn here
+                return;
+            case 7: // Digits (below the crosshair)
+            {
+                defformatstring(numstr, "%d", number);
+                int tw, th; text_bounds(numstr, tw, th);
+                if(th <= 0) return;
+                float scl = 0.9f + 0.30f * beatpunch(t);
