+    // === MAPBATTLE test replica: reproduces the RUGBY-family intermission vote flow ===
+    // (for testing the SwiftGibs map-vote panel locally; NOT shipped in any bundle)
+    const char *mbpool[6] = { "reissen", "earthstation", "luna", "forge", "campo", "metro" };
+    int mbpoolpos = 0;
+    string mbcand[3];
+    int mbvotes[3];
+    int mbclientvote[MAXCLIENTS];
+    bool mbactive = false;
+    int mbendmillis = 0;
+
+    void mbstart()
+    {
+        loopi(3) { copystring(mbcand[i], mbpool[(mbpoolpos + i) % 6]); mbvotes[i] = 0; }
+        mbpoolpos = (mbpoolpos + 1) % 6;
+        loopi(MAXCLIENTS) mbclientvote[i] = -1;
+        mbactive = true;
+        mbendmillis = totalmillis + 20000;   // votes always conclude 20s after they start
+        // deliberately ONE message with embedded newlines - the real server batches like this
+        sendservmsgf("[MAPBATTLE] Vote with a number:\n[MAPBATTLE] %s: (1) - %s: (2) - %s: (3)",
+            mbcand[0], mbcand[1], mbcand[2]);
+    }
+
+    void mbstart();
+    bool mbhandlesay(clientinfo *ci, const char *text)
+    {
+        if(ci && !strcmp(text, "startvote"))
+        {
+            if(!mbactive) mbstart();
+            else sendf(ci->clientnum, 1, "ris", N_SERVMSG, "[MAPBATTLE] a vote is already running");
+            return true;
+        }
+        if(!mbactive || !ci) return false;
+        if(strlen(text) != 1 || text[0] < '1' || text[0] > '3') return false;
+        int pick = text[0] - '1', cn = ci->clientnum;
+        if(cn < 0 || cn >= MAXCLIENTS) return false;
+        if(mbclientvote[cn] >= 0) mbvotes[mbclientvote[cn]]--;
+        mbclientvote[cn] = pick;
+        mbvotes[pick]++;
+        sendservmsgf("[MAPBATTLE] %s: %d - %s: %d - %s: %d (Voted by %s)",
+            mbcand[0], mbvotes[0], mbcand[1], mbvotes[1], mbcand[2], mbvotes[2], colorname(ci));
+        return true;
+    }
+
+    void mbfinish()
+    {
+        if(!mbactive) return;
+        mbactive = false;
+        int best = 0;
+        loopi(3) if(mbvotes[i] > mbvotes[best]) best = i;
+        sendservmsgf("WINNER >> %s (%d votes)", mbcand[best], mbvotes[best]);
+        changemap(mbcand[best], gamemode);
+    }
+    // === end MAPBATTLE test replica ===
+
